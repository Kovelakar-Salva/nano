.mbr-tag { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; font-weight: 500; color: var(--text); }
.mbr-meta { font-size: 11px; color: var(--text3); font-family: 'JetBrains Mono', monospace; }
.mbr-pin { font-size: 11px; color: var(--text4); white-space: nowrap; }
.mbr-pin.pinned { color: var(--blue); }

.map-no-data { padding: 24px; text-align: center; font-size: 12px; color: var(--text4); }

