.anchor-chip {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px; font-weight: 500;
  padding: 3px 9px; border-radius: 99px;
  background: var(--blue-bg); border: 1px solid rgba(0,113,227,.2);
  color: var(--blue);
}

/* Beacon list */
