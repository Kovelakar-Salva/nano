  if (inp.type === 'password') {
    inp.type = 'text';
    svg.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
  } else {
    inp.type = 'password';
    svg.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
  }
}

function doLogin() {
  const email = document.getElementById('inp-email').value.trim();
  const pass  = document.getElementById('inp-pass').value;
  const errEl = document.getElementById('login-error');
  const btn   = document.getElementById('btn-login');
  const lbl   = document.getElementById('btn-login-label');

  if (!email || !pass) { showLoginErr('Please enter your email and password.'); return; }

  errEl.classList.remove('show');
  btn.disabled = true;
  lbl.innerHTML = '<span class="spinner"></span>Signing in…';

  auth.signInWithEmailAndPassword(email, pass)
    .then(result => { /* onAuthStateChanged handles the rest */ })
    .catch(err => {
      btn.disabled = false;
      lbl.textContent = 'Sign In';
      const msg = err.code === 'auth/user-not-found' || err.code === 'auth/wrong-password'
        ? 'Incorrect email or password.' : err.message;
      showLoginErr(msg);
    });
}

function showLoginErr(msg) {
  const el = document.getElementById('login-error');
  el.textContent = msg;
  el.classList.remove('show');
  void el.offsetWidth;
  el.classList.add('show');
}

function showLogin() {
  document.getElementById('screen-login').style.display = 'flex';
  document.getElementById('screen-app').style.display  = 'none';
  const btn = document.getElementById('btn-login');
  const lbl = document.getElementById('btn-login-label');
  if (btn) { btn.disabled = false; lbl.textContent = 'Sign In'; }
}

function onLoginSuccess(user) {
  // clientId = email prefix (e.g. "acme" from "acme@wallenc.com")
  // In production, store clientId in Firebase user profile / custom claims
  clientId = user.email.split('@')[0].replace(/[^a-z0-9_]/gi, '_');

  const initials = user.displayName
    ? user.displayName.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase()
    : user.email.slice(0,2).toUpperCase();

  document.getElementById('user-av').textContent      = initials;
  document.getElementById('user-name').textContent    = user.displayName || user.email.split('@')[0];
  document.getElementById('user-client').textContent  = clientId;

  // Restore saved Firebase URL
  const savedUrl = localStorage.getItem('we_url_' + clientId);
  if (savedUrl) document.getElementById('fb-url').value = savedUrl;

  // Hide login → show app with fade
  const ls = document.getElementById('screen-login');
  ls.style.transition = 'opacity .4s ease';
  ls.style.opacity = '0';
  setTimeout(() => {
    ls.style.display = 'none';
    document.getElementById('screen-app').style.display = 'block';
    resizeCanvas();
    if (savedUrl) startDashboard();
  }, 380);

  log(`Signed in as ${user.email}`, 'ok');
}

function doLogout() {
  if (pollTimer) clearInterval(pollTimer);
  auth.signOut().then(() => {
    currentUser = null;
    // Reset state
    Object.keys(beacons).forEach(k => delete beacons[k]);
    document.getElementById('beacon-grid').innerHTML = '<div class="empty-state" id="empty-state"><div class="empty-icon">📡</div><div class="empty-title">No beacons detected</div><div class="empty-sub">Enter your Firebase URL in the sidebar and click Connect</div></div>';
    document.getElementById('map-beacon-list').innerHTML = '<div class="map-no-data">Connect to Firebase first</div>';
    setConn(false, true);
    const ls = document.getElementById('screen-login');
    ls.style.opacity = '0'; ls.style.display = 'flex';
    setTimeout(() => { ls.style.transition = 'opacity .3s'; ls.style.opacity = '1'; }, 10);
    document.getElementById('screen-app').style.display = 'none';
  });
}

// Enter key
document.getElementById('inp-pass').addEventListener('keydown', e => { if (e.key === 'Enter') doLogin(); });
document.getElementById('inp-email').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('inp-pass').focus(); });

// ══════════════════════════════════════════════════════
// NAV
// ══════════════════════════════════════════════════════
const viewTitles = { overview: 'Overview', map: 'Map View', alerts: 'Alerts' };

function switchView(name, btn) {
  document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('view-' + name).classList.add('active');
  document.getElementById('topbar-title').textContent = viewTitles[name] || name;
  if (name === 'map') setTimeout(() => { resizeCanvas(); drawFloorPlan(); }, 80);
}

// ══════════════════════════════════════════════════════
// LOG
// ══════════════════════════════════════════════════════
function log(msg, type = 'info') {
  const wrap = document.getElementById('log-entries');
  if (!wrap) return;
  const d = document.createElement('div');
  d.className = 'log-line ' + type;
  d.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
  wrap.prepend(d);
  while (wrap.children.length > 100) wrap.removeChild(wrap.lastChild);
}
function clearLog() { document.getElementById('log-entries').innerHTML = ''; }

// ══════════════════════════════════════════════════════
// CONNECT TO FIREBASE REST
// ══════════════════════════════════════════════════════
function startDashboard() {
  dbUrl = document.getElementById('fb-url').value.trim().replace(/\/$/, '');
  if (!dbUrl) { log('Please enter a Firebase URL', 'err'); return; }
  localStorage.setItem('we_url_' + clientId, dbUrl);
  log(`Connecting…`, 'info');
  if (pollTimer) clearInterval(pollTimer);
  poll();
  pollTimer = setInterval(poll, 3000);
}

async function poll() {
  if (!dbUrl || !clientId) return;
  try {
    const r = await fetch(`${dbUrl}/clients/${clientId}/beacons.json`);
    if (!r.ok) { log(`HTTP ${r.status} — check Firebase rules`, 'err'); setConn(false); return; }
    const data = await r.json();
    setConn(true);
    if (!data) return;
    processData(data);
  } catch (e) { log(`Network error: ${e.message}`, 'err'); setConn(false); }
}

function setConn(ok, idle = false) {
  const dot   = document.getElementById('conn-dot');
  const label = document.getElementById('conn-label');
  const tpill = document.getElementById('topbar-pill');
  const tdot  = document.getElementById('topbar-dot');
  const ts    = document.getElementById('topbar-status');

  if (idle) {
    dot.className = 'conn-dot';
    label.textContent = 'Not connected';
    tpill.className = 'topbar-pill idle';
    ts.textContent = 'Idle';
    return;
  }

  dot.className   = 'conn-dot ' + (ok ? 'live' : 'err');
  label.textContent = ok ? 'Live' : 'Error';
  tpill.className = 'topbar-pill ' + (ok ? 'live' : 'err');
  ts.textContent  = ok ? 'Live' : 'Error';
}

// ══════════════════════════════════════════════════════
// PROCESS DATA
// ══════════════════════════════════════════════════════
function processData(data) {
  const now = Date.now() / 1000;
  let mo = 0, ta = 0, latest = 0, active = 0;

  for (const [id, raw] of Object.entries(data)) {
    const d = raw.live || raw;
    const prev = beacons[id];
    const isNew = !prev, changed = prev && JSON.stringify(prev) !== JSON.stringify(d);
    beacons[id] = d;

    const age = now - (d.timestamp_rx || 0);
    if (age < 30) active++;
    if (d.motion) mo++;
    if (d.tamper) ta++;
    if ((d.timestamp_rx || 0) > latest) latest = d.timestamp_rx;

    if (isNew) log(`New beacon: ${id}`, 'ok');
    if (changed && !isNew) log(`${id}  rssi=${d.rssi}  bat=${batPct(d.battery||0)}%`, 'info');

    renderBeaconCard(id, d, changed || isNew);
    renderMapRow(id, d);
    updatePin(id);
    addAnchorChip(d.anchor_id);
  }

  document.getElementById('s-active').textContent      = active;
  document.getElementById('s-total').textContent       = Object.keys(beacons).length;
  document.getElementById('s-motion').textContent      = mo;
  document.getElementById('s-tamper').textContent      = ta;
  document.getElementById('s-lastupdate').textContent  = latest ? new Date(latest * 1000).toLocaleTimeString() : '—';
  document.getElementById('nav-active-count').textContent = active;

  const ac = document.getElementById('nav-alert-count');
  if (mo + ta > 0) { ac.textContent = mo + ta; ac.style.display = 'flex'; }
  else { ac.style.display = 'none'; }

  const em = document.getElementById('empty-state'); if (em) em.remove();
}

// ══════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════
const sigColor  = r => r > -60 ? 'var(--green)' : r > -80 ? 'var(--amber)' : 'var(--red)';
const sigPct    = r => Math.max(0, Math.min(100, ((r + 100) / 60) * 100));
const batPct    = b => Math.min(100, Math.round((b / 200) * 100));
const batColor  = b => { const p = batPct(b); return p > 60 ? 'var(--green)' : p > 30 ? 'var(--amber)' : 'var(--red)'; };
const ageStatus = ts => { const a = Date.now()/1000-(ts||0); return a<30?'online':a<120?'stale':'offline'; };
const pinColor  = d => { const ta=d.tamper==1||d.tamper===true, mo=d.motion==1||d.motion===true, st=ageStatus(d.timestamp_rx); return ta?'#ff3b30':mo?'#ff9500':st==='online'?'#34c759':st==='stale'?'#ff9500':'#aeaeb2'; };

// ══════════════════════════════════════════════════════
// RENDER BEACON CARD
// ══════════════════════════════════════════════════════
function renderBeaconCard(id, d, flash) {
  const grid = document.getElementById('beacon-grid');
  let c = document.getElementById('bc-' + id);
  if (!c) { c = document.createElement('div'); c.className = 'beacon-card'; c.id = 'bc-' + id; grid.appendChild(c); }

  const mo = d.motion == 1 || d.motion === true;
  const ta = d.tamper == 1 || d.tamper === true;
  const st = ageStatus(d.timestamp_rx);
  const ts = d.timestamp_rx ? new Date(d.timestamp_rx * 1000).toLocaleTimeString() : '—';
  const sp = sigPct(d.rssi || 0), sc = sigColor(d.rssi || 0);
  const bp = batPct(d.battery || 0), bc = batColor(d.battery || 0);

  c.innerHTML = `
    <div class="bc-head">
      <div class="bc-left">
        <div class="bc-avatar ${st}">${id.slice(-3)}</div>
        <div>
          <div class="bc-tag">${id}</div>
          <div class="bc-anchor">${d.anchor_id || '—'} · ${d.product_id || '—'}</div>
        </div>
      </div>
      <div class="status-dot ${st}"></div>
    </div>
    <div class="bc-signal">
      <div class="bc-signal-row">
        <span class="bc-signal-label">Signal strength</span>
        <span class="bc-signal-val" style="color:${sc}">${d.rssi || '—'} dBm</span>
      </div>
      <div class="signal-track"><div class="signal-fill" style="width:${sp}%;background:${sc}"></div></div>
    </div>
    <div class="bc-metrics">
      <div class="bc-metric">
        <div class="bc-metric-label">Battery</div>
        <div class="bc-metric-val" style="color:${bc}">${bp}%</div>
      </div>
      <div class="bc-metric">
        <div class="bc-metric-label">Counter</div>
        <div class="bc-metric-val">${d.counter !== undefined ? d.counter : '—'}</div>
      </div>
      <div class="bc-metric">
        <div class="bc-metric-label">Status</div>
        <div class="bc-metric-val" style="font-size:11px;color:${st==='online'?'var(--green)':st==='stale'?'var(--amber)':'var(--text4)'}">${st}</div>
      </div>
    </div>
    <div class="bc-flags">
      <span class="flag ${mo ? 'flag-motion' : 'flag-clear'}">motion ${mo ? 'active' : 'clear'}</span>
      <span class="flag ${ta ? 'flag-tamper' : 'flag-clear'}">tamper ${ta ? 'alert' : 'clear'}</span>
    </div>
    <div class="bc-footer">
      <span class="bc-mac">${d.mac || '—'}</span>
      <span class="bc-ts">${ts}</span>
    </div>`;

  if (flash) { c.classList.remove('flash'); void c.offsetWidth; c.classList.add('flash'); }
}

// ══════════════════════════════════════════════════════
// MAP ROW
// ══════════════════════════════════════════════════════
function renderMapRow(id, d) {
  const list = document.getElementById('map-beacon-list');
  const nd = list.querySelector('.map-no-data'); if (nd) nd.remove();
  let row = document.getElementById('mr-' + id);
  if (!row) {
    row = document.createElement('div');
    row.className = 'map-beacon-row';
    row.id = 'mr-' + id;
    row.onclick = () => selectBeacon(id);
    list.appendChild(row);
  }
  const st = ageStatus(d.timestamp_rx);
  const col = pinColor(d);
  const pinned = !!pins[id];
  row.innerHTML = `
    <div class="mbr-dot" style="background:${col}"></div>
    <div class="mbr-info">
      <div class="mbr-tag">${id}</div>
      <div class="mbr-meta">${d.rssi || '?'} dBm · bat ${batPct(d.battery||0)}%</div>
    </div>
    <div class="mbr-pin ${pinned ? 'pinned' : ''}">${pinned ? '📍' : '○'}</div>`;
}

function selectBeacon(id) {
  selTag = id;
  document.querySelectorAll('.map-beacon-row').forEach(r => r.classList.remove('sel'));
  const el = document.getElementById('mr-' + id); if (el) el.classList.add('sel');
  if (placeMode) document.getElementById('place-hint').textContent = `Click floor plan to place: ${id}`;
  const pin = document.getElementById('pin-' + id);
  if (pin) pin.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function addAnchorChip(id) {
  if (!id || knownAnchors.has(id)) return;
  knownAnchors.add(id);
  const wrap = document.getElementById('anchor-chips');
  const chip = document.createElement('span');
  chip.className = 'anchor-chip'; chip.textContent = id;
  wrap.appendChild(chip);
}

// ══════════════════════════════════════════════════════
// FLOOR PLAN CANVAS
// ══════════════════════════════════════════════════════
function resizeCanvas() {
  const wrap = document.getElementById('canvas-wrap');
  const c = document.getElementById('fp-canvas');
  c.width = wrap.clientWidth; c.height = wrap.clientHeight;
}

function drawFloorPlan() {
  const c = document.getElementById('fp-canvas');
  const ctx = c.getContext('2d');
  ctx.clearRect(0, 0, c.width, c.height);
  if (!fpImg) return;
  ctx.save();
  ctx.translate(offsetX, offsetY); ctx.scale(scale, scale);
  ctx.drawImage(fpImg, 0, 0, fpImg.width, fpImg.height);
  ctx.strokeStyle = 'rgba(0,113,227,0.05)'; ctx.lineWidth = 1 / scale;
  for (let x = 0; x < fpImg.width; x += 50) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,fpImg.height); ctx.stroke(); }
  for (let y = 0; y < fpImg.height; y += 50) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(fpImg.width,y); ctx.stroke(); }
  ctx.restore();
  document.getElementById('map-info').textContent = `${Math.round(scale*100)}% · ${fpImg.width}×${fpImg.height}px`;
}

function loadFloorPlan(input) {
  const file = input.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const img = new Image();
    img.onload = () => {
      fpImg = img; resizeCanvas();
      const wrap = document.getElementById('canvas-wrap');
      const s = Math.min(wrap.clientWidth / img.width, wrap.clientHeight / img.height) * 0.9;
      scale = s;
      offsetX = (wrap.clientWidth - img.width * s) / 2;
      offsetY = (wrap.clientHeight - img.height * s) / 2;
      drawFloorPlan();
      document.getElementById('canvas-empty').style.display = 'none';
      document.getElementById('fp-upload-area').style.display = 'none';
      document.getElementById('fp-loaded').style.display = 'flex';
      document.getElementById('fp-loaded-name').textContent = file.name;
      document.getElementById('place-hint').classList.add('show');
      log(`Floor plan loaded: ${file.name}`, 'ok');
      Object.keys(pins).forEach(updatePin);
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function clearFloorPlan() {
  fpImg = null;
  const c = document.getElementById('fp-canvas');
  c.getContext('2d').clearRect(0, 0, c.width, c.height);
  document.getElementById('canvas-empty').style.display = 'flex';
  document.getElementById('fp-upload-area').style.display = 'block';
  document.getElementById('fp-loaded').style.display = 'none';
  document.getElementById('fp-file').value = '';
  document.getElementById('map-info').textContent = 'No floor plan';
  log('Floor plan cleared', 'info');
}

function doZoom(f) {
  const wrap = document.getElementById('canvas-wrap');
  const cx = wrap.clientWidth / 2, cy = wrap.clientHeight / 2;
  const ns = Math.min(8, Math.max(0.08, scale * f));
  offsetX = cx - (cx - offsetX) * (ns / scale);
  offsetY = cy - (cy - offsetY) * (ns / scale);
  scale = ns; drawFloorPlan(); updateAllPins();
}

function resetMapView() {
  if (!fpImg) return;
  const wrap = document.getElementById('canvas-wrap');
  const s = Math.min(wrap.clientWidth / fpImg.width, wrap.clientHeight / fpImg.height) * 0.9;
  scale = s;
  offsetX = (wrap.clientWidth - fpImg.width * s) / 2;
  offsetY = (wrap.clientHeight - fpImg.height * s) / 2;
  drawFloorPlan(); updateAllPins();
}

const i2s = (ix, iy) => ({ x: offsetX + ix * scale, y: offsetY + iy * scale });
const s2i = (sx, sy) => ({ x: (sx - offsetX) / scale, y: (sy - offsetY) / scale });

const cw = document.getElementById('canvas-wrap');

cw.addEventListener('mousedown', e => {
  if (placeMode && selTag && fpImg) {
    const rect = cw.getBoundingClientRect();
    const ic = s2i(e.clientX - rect.left, e.clientY - rect.top);
    if (ic.x >= 0 && ic.x <= fpImg.width && ic.y >= 0 && ic.y <= fpImg.height) {
      pins[selTag] = { ix: ic.x, iy: ic.y };
      updatePin(selTag);
      renderMapRow(selTag, beacons[selTag] || {});
      log(`${selTag} placed on floor plan`, 'ok');
      return;
    }
  }
  isDragging = true; dragSX = e.clientX; dragSY = e.clientY; dragOX = offsetX; dragOY = offsetY;
  cw.style.cursor = 'grabbing';
});

window.addEventListener('mousemove', e => {
  if (!isDragging) return;
  offsetX = dragOX + (e.clientX - dragSX);
  offsetY = dragOY + (e.clientY - dragSY);
  drawFloorPlan(); updateAllPins();
});

window.addEventListener('mouseup', () => {
  isDragging = false;
  cw.style.cursor = placeMode ? 'crosshair' : 'grab';
});

cw.addEventListener('wheel', e => {
  e.preventDefault();
  const rect = cw.getBoundingClientRect();
  const mx = e.clientX - rect.left, my = e.clientY - rect.top;
  const f = e.deltaY < 0 ? 1.12 : 0.88;
  const ns = Math.min(8, Math.max(0.08, scale * f));
  offsetX = mx - (mx - offsetX) * (ns / scale);
  offsetY = my - (my - offsetY) * (ns / scale);
  scale = ns; drawFloorPlan(); updateAllPins();
}, { passive: false });

window.addEventListener('resize', () => { resizeCanvas(); drawFloorPlan(); updateAllPins(); });

// ══════════════════════════════════════════════════════
// PINS
// ══════════════════════════════════════════════════════
function updatePin(id) {
  const d = beacons[id] || {}, p = pins[id];
  if (!p) { const el = document.getElementById('pin-'+id); if (el) el.remove(); return; }
  const sc2 = i2s(p.ix, p.iy);
  const color = pinColor(d);
  const mo = d.motion==1||d.motion===true, ta = d.tamper==1||d.tamper===true;
  const st = ageStatus(d.timestamp_rx);
  const ts = d.timestamp_rx ? new Date(d.timestamp_rx*1000).toLocaleTimeString() : '—';
  const pulse = mo || ta;

  let el = document.getElementById('pin-'+id);
  if (!el) { el = document.createElement('div'); el.className = 'beacon-pin'; el.id = 'pin-'+id; el.onclick = () => selectBeacon(id); cw.appendChild(el); }

  el.style.left = sc2.x + 'px'; el.style.top = sc2.y + 'px'; el.style.color = color;
  el.innerHTML = `
    <div class="pin-outer ${pulse ? 'pulse' : ''}"></div>
    <div class="pin-body" style="background:${color}">
      <span class="pin-text">${id.slice(-3)}</span>
    </div>
    <div class="pin-tooltip">
      <div class="ptt-tag">${id}</div>
      <div class="ptt-row"><span class="ptt-k">Signal</span><span class="ptt-v" style="color:${sigColor(d.rssi||0)}">${d.rssi||'—'} dBm</span></div>
      <div class="ptt-row"><span class="ptt-k">Battery</span><span class="ptt-v">${batPct(d.battery||0)}%</span></div>
      <div class="ptt-row"><span class="ptt-k">Motion</span><span class="ptt-v" style="color:${mo?'var(--amber)':'var(--green)'}">${mo?'Active':'Clear'}</span></div>
      <div class="ptt-row"><span class="ptt-k">Tamper</span><span class="ptt-v" style="color:${ta?'var(--red)':'var(--green)'}">${ta?'Alert':'Clear'}</span></div>
      <div class="ptt-row"><span class="ptt-k">Status</span><span class="ptt-v">${st}</span></div>
      <div class="ptt-row"><span class="ptt-k">Last seen</span><span class="ptt-v">${ts}</span></div>
    </div>`;
}

function updateAllPins() {
  Object.keys(pins).forEach(id => {
    const el = document.getElementById('pin-'+id), p = pins[id];
    if (!el || !p) return;
    const sc2 = i2s(p.ix, p.iy);
    el.style.left = sc2.x + 'px'; el.style.top = sc2.y + 'px';
  });
}

function clearPins() {
  Object.keys(pins).forEach(id => { const el = document.getElementById('pin-'+id); if (el) el.remove(); delete pins[id]; });
  Object.keys(beacons).forEach(id => renderMapRow(id, beacons[id]));
  log('All pins cleared', 'info');
}

function togglePlaceMode() {
  placeMode = !placeMode;
  const btn = document.getElementById('btn-place');
  const hint = document.getElementById('place-hint');
  btn.classList.toggle('active', placeMode);
  hint.classList.toggle('show', placeMode);
  if (placeMode) {
    hint.textContent = selTag ? `Click floor plan to place: ${selTag}` : 'Select a beacon from the list first';
    cw.style.cursor = 'crosshair';
  } else {
    hint.textContent = 'Select a beacon below, then click the floor plan to place it';
    cw.style.cursor = 'grab';
  }
}

// Init
window.onload = () => { resizeCanvas(); };
