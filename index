.canvas-empty-icon { font-size: 52px; opacity: .2; }
.canvas-empty-title { font-size: 14px; font-weight: 500; color: var(--text3); }
.canvas-empty-sub { font-size: 12px; }

/* Beacon pin */
.beacon-pin {
  position: absolute; transform: translate(-50%,-50%);
  cursor: pointer; z-index: 10;
}

.pin-outer {
  position: absolute; inset: -6px; border-radius: 50%;
  border: 2px solid currentColor; opacity: .2;
}

.pin-outer.pulse { animation: pinpulse 1.6s ease-in-out infinite; }
@keyframes pinpulse { 0%,100%{transform:scale(1);opacity:.2;} 50%{transform:scale(1.7);opacity:.05;} }

.pin-body {
  width: 30px; height: 30px; border-radius: 50%;
  background: currentColor;
  border: 3px solid white;
  box-shadow: 0 2px 10px rgba(0,0,0,.15);
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 1;
}

.pin-text { font-family: 'JetBrains Mono', monospace; font-size: 8px; font-weight: 700; color: white; }

/* Pin tooltip */
.pin-tooltip {
  position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
