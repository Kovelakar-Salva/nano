<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WallEnc</title>
<!-- Firebase SDK -->
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=SF+Pro+Display:wght@300;400;500;600;700&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

:root {
  /* Apple-inspired palette */
  --bg:        #f5f5f7;
  --surface:   #ffffff;
  --surface2:  #f5f5f7;
  --surface3:  #e8e8ed;
  --border:    rgba(0,0,0,0.08);
  --border2:   rgba(0,0,0,0.12);

  --text:      #1d1d1f;
  --text2:     #424245;
  --text3:     #86868b;
  --text4:     #aeaeb2;

  --blue:      #0071e3;
  --blue-l:    #2997ff;
  --blue-d:    #0051a2;
  --blue-bg:   rgba(0,113,227,0.08);
  --blue-bg2:  rgba(0,113,227,0.14);

  --green:     #34c759;
  --green-bg:  rgba(52,199,89,0.1);
  --amber:     #ff9500;
  --amber-bg:  rgba(255,149,0,0.1);
  --red:       #ff3b30;
  --red-bg:    rgba(255,59,48,0.1);

  --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadow:    0 4px 16px rgba(0,0,0,0.08), 0 1px 4px rgba(0,0,0,0.04);
  --shadow-lg: 0 12px 40px rgba(0,0,0,0.12), 0 4px 12px rgba(0,0,0,0.06);

  --r-sm: 8px;
  --r:    12px;
  --r-lg: 16px;
  --r-xl: 20px;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  font-size: 14px;
  -webkit-font-smoothing: antialiased;
}

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 99px; }
::-webkit-scrollbar-thumb:hover { background: var(--text4); }

/* ═══════════════════════════════════
   LOGIN — Apple-style centered card
═══════════════════════════════════ */
#screen-login {
  position: fixed; inset: 0; z-index: 999;
  background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  padding: 24px;
}

/* subtle mesh background */
#screen-login::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 30% 20%, rgba(0,113,227,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 80% 80%, rgba(0,113,227,0.04) 0%, transparent 55%);
  pointer-events: none;
}

.login-wrap {
  width: 100%; max-width: 380px;
  animation: fadeUp .5s cubic-bezier(.16,1,.3,1) both;
}

@keyframes fadeUp {
  from { opacity:0; transform:translateY(20px); }
  to   { opacity:1; transform:translateY(0); }
}

.login-brand {
  display: flex; flex-direction: column; align-items: center;
  margin-bottom: 32px; gap: 12px;
}

.login-icon {
  width: 56px; height: 56px;
  background: var(--blue);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8px 24px rgba(0,113,227,0.3);
}

.login-icon svg { width: 28px; height: 28px; fill: white; }

.login-brand-name {
  font-size: 22px; font-weight: 600;
  color: var(--text); letter-spacing: -0.03em;
}

.login-brand-name span { color: var(--blue); }

.login-card {
  background: var(--surface);
  border-radius: var(--r-xl);
  padding: 32px;
  box-shadow: var(--shadow-lg);
  border: 1px solid var(--border);
}

.login-title {
  font-size: 17px; font-weight: 600;
  color: var(--text); margin-bottom: 4px; letter-spacing: -0.02em;
}

.login-sub {
  font-size: 13px; color: var(--text3);
  margin-bottom: 24px; font-weight: 400;
}

.form-field { margin-bottom: 12px; }

.form-label {
  display: block; font-size: 12px; font-weight: 500;
  color: var(--text2); margin-bottom: 6px; letter-spacing: .01em;
}

.form-input-wrap { position: relative; }

.form-input {
  width: 100%; height: 42px;
  background: var(--surface2);
  border: 1.5px solid var(--border2);
  border-radius: var(--r-sm);
  color: var(--text);
  font-family: 'Inter', sans-serif; font-size: 14px;
  padding: 0 40px 0 14px;
  outline: none;
  transition: border-color .15s, box-shadow .15s;
  -webkit-appearance: none;
}

.form-input::placeholder { color: var(--text4); }

.form-input:focus {
  border-color: var(--blue);
  background: var(--surface);
  box-shadow: 0 0 0 3px rgba(0,113,227,0.12);
}

.input-icon {
  position: absolute; right: 13px; top: 50%; transform: translateY(-50%);
  color: var(--text4); pointer-events: none;
}

.input-icon svg { width: 15px; height: 15px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

.eye-toggle {
  position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
  background: none; border: none; cursor: pointer;
  color: var(--text3); padding: 2px; transition: color .15s;
}
.eye-toggle:hover { color: var(--text2); }
.eye-toggle svg { width: 15px; height: 15px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; display: block; }

.login-error {
  display: none;
  background: var(--red-bg);
  border: 1px solid rgba(255,59,48,0.2);
  border-radius: var(--r-sm);
  padding: 10px 14px;
  font-size: 12.5px; color: var(--red);
  margin-bottom: 14px;
}
.login-error.show { display: block; animation: shake .3s ease; }
@keyframes shake { 0%,100%{transform:translateX(0);} 25%{transform:translateX(-5px);} 75%{transform:translateX(5px);} }

.btn-primary {
  width: 100%; height: 44px;
  background: var(--blue);
  color: white; border: none;
  border-radius: var(--r-sm);
  font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 600;
  cursor: pointer; letter-spacing: -.01em;
  transition: background .15s, transform .1s, box-shadow .15s;
  box-shadow: 0 2px 8px rgba(0,113,227,0.25);
  margin-top: 6px;
}
.btn-primary:hover { background: var(--blue-l); box-shadow: 0 4px 16px rgba(0,113,227,0.35); }
.btn-primary:active { transform: scale(.98); }
.btn-primary:disabled { opacity: .6; pointer-events: none; }

.btn-primary .spinner {
  display: inline-block; width: 15px; height: 15px;
  border: 2px solid rgba(255,255,255,.3); border-top-color: white;
  border-radius: 50%; animation: spin .6s linear infinite;
  vertical-align: middle; margin-right: 7px;
}
@keyframes spin { to { transform: rotate(360deg); } }

.login-footer {
  margin-top: 20px; text-align: center;
  font-size: 12px; color: var(--text4);
}

/* ═══════════════════════════════════
   APP SHELL
═══════════════════════════════════ */
#screen-app { display: none; min-height: 100vh; }

/* SIDEBAR NAV — Apple sidebar style */
.app-layout {
  display: flex; min-height: 100vh;
}

.sidebar {
  width: 240px; min-width: 240px;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  position: sticky; top: 0; height: 100vh;
  overflow: hidden;
}

.sidebar-header {
  padding: 20px 16px 16px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.sidebar-brand {
  display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
}

.sidebar-icon {
  width: 32px; height: 32px;
  background: var(--blue);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.sidebar-icon svg { width: 18px; height: 18px; fill: white; }

.sidebar-brand-name {
  font-size: 16px; font-weight: 700;
  color: var(--text); letter-spacing: -0.03em;
}

.sidebar-brand-name span { color: var(--blue); }

.sidebar-user {
  display: flex; align-items: center; gap: 10px;
  background: var(--surface2);
  border-radius: var(--r-sm);
  padding: 8px 10px;
}

.user-avatar {
  width: 30px; height: 30px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--blue), var(--blue-d));
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 600; color: white;
  flex-shrink: 0;
}

.user-info { flex: 1; min-width: 0; }
.user-display { font-size: 12px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.user-client { font-size: 11px; color: var(--text3); font-family: 'JetBrains Mono', monospace; }

/* NAV */
.sidebar-nav { padding: 12px 10px; flex: 1; overflow-y: auto; }

.nav-section { margin-bottom: 20px; }

.nav-section-label {
  font-size: 10px; font-weight: 600;
  color: var(--text4); text-transform: uppercase;
  letter-spacing: .08em; padding: 0 8px; margin-bottom: 4px;
}

.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 8px 10px;
  border-radius: var(--r-sm);
  cursor: pointer;
  transition: background .12s;
  color: var(--text2); font-size: 13.5px; font-weight: 500;
  border: none; background: none; width: 100%; text-align: left;
}

.nav-item:hover { background: var(--surface2); color: var(--text); }

.nav-item.active {
  background: var(--blue-bg);
  color: var(--blue);
}

.nav-item svg {
  width: 17px; height: 17px; flex-shrink: 0;
  fill: none; stroke: currentColor; stroke-width: 1.8;
  stroke-linecap: round; stroke-linejoin: round;
  opacity: .8;
}

.nav-item.active svg { opacity: 1; }

.nav-badge {
  margin-left: auto;
  min-width: 18px; height: 18px;
  background: var(--red);
  color: white; font-size: 10px; font-weight: 600;
  border-radius: 99px; padding: 0 5px;
  display: flex; align-items: center; justify-content: center;
}

.nav-badge.blue { background: var(--blue); }

/* SIDEBAR FOOTER */
.sidebar-footer {
  padding: 12px 10px;
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}

/* Firebase config in sidebar */
.fb-config { padding: 10px 8px; }

.fb-config-label {
  font-size: 10px; font-weight: 600; color: var(--text4);
  text-transform: uppercase; letter-spacing: .08em;
  margin-bottom: 8px;
}

.fb-input {
  width: 100%; height: 34px;
  background: var(--surface2);
  border: 1.5px solid var(--border2);
  border-radius: var(--r-sm);
  color: var(--text); font-family: 'JetBrains Mono', monospace; font-size: 10px;
  padding: 0 10px; outline: none; margin-bottom: 6px;
  transition: border-color .15s;
}

.fb-input:focus { border-color: var(--blue); }

.btn-connect {
  width: 100%; height: 32px;
  background: var(--blue);
  color: white; border: none; border-radius: var(--r-sm);
  font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600;
  cursor: pointer; transition: background .15s;
}

.btn-connect:hover { background: var(--blue-l); }

.conn-status {
  display: flex; align-items: center; gap: 6px;
  font-size: 11px; color: var(--text3); margin-top: 6px;
  font-family: 'JetBrains Mono', monospace;
}

.conn-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--text4); flex-shrink: 0;
}

.conn-dot.live { background: var(--green); box-shadow: 0 0 0 2px rgba(52,199,89,.2); animation: livepulse 2s ease infinite; }
.conn-dot.err  { background: var(--red); }
@keyframes livepulse { 0%,100%{box-shadow:0 0 0 2px rgba(52,199,89,.2);} 50%{box-shadow:0 0 0 4px rgba(52,199,89,.1);} }

.btn-logout {
  width: 100%; height: 34px;
  background: none; border: 1.5px solid var(--border2);
  border-radius: var(--r-sm); color: var(--text3);
  font-family: 'Inter', sans-serif; font-size: 12.5px; font-weight: 500;
  cursor: pointer; transition: all .15s; margin-top: 6px;
  display: flex; align-items: center; justify-content: center; gap: 6px;
}

.btn-logout:hover { background: var(--red-bg); border-color: rgba(255,59,48,.3); color: var(--red); }
.btn-logout svg { width: 14px; height: 14px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

/* MAIN CONTENT */
.main {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column;
  overflow: hidden;
}

/* TOP BAR */
.topbar {
  height: 52px;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center;
  padding: 0 24px; gap: 16px;
  position: sticky; top: 0; z-index: 50;
  flex-shrink: 0;
}

.topbar-title {
  font-size: 15px; font-weight: 600;
  color: var(--text); letter-spacing: -0.02em;
  flex: 1;
}

.topbar-clock {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px; color: var(--text3);
}

.topbar-pill {
  display: flex; align-items: center; gap: 5px;
  font-size: 11px; font-weight: 500;
  padding: 4px 10px; border-radius: 99px;
  border: 1px solid;
}

.topbar-pill.live { color: var(--green); background: var(--green-bg); border-color: rgba(52,199,89,.3); }
.topbar-pill.err  { color: var(--red);   background: var(--red-bg);   border-color: rgba(255,59,48,.3); }
.topbar-pill.idle { color: var(--text3); background: var(--surface2); border-color: var(--border2); }

/* VIEWS */
.view { display: none; flex: 1; overflow-y: auto; }
.view.active { display: flex; flex-direction: column; }

/* ═══════════════════════════════════
   OVERVIEW VIEW
═══════════════════════════════════ */
#view-overview { padding: 24px; gap: 20px; }

/* Stat cards */
.stat-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 12px;
}

.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 18px 20px;
  box-shadow: var(--shadow-sm);
  transition: box-shadow .2s, transform .2s;
}

.stat-card:hover { box-shadow: var(--shadow); transform: translateY(-1px); }

.stat-card-icon {
  width: 36px; height: 36px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 12px;
}

.stat-card-icon svg { width: 18px; height: 18px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

.stat-card-icon.blue  { background: var(--blue-bg);  color: var(--blue); }
.stat-card-icon.green { background: var(--green-bg); color: var(--green); }
.stat-card-icon.amber { background: var(--amber-bg); color: var(--amber); }
.stat-card-icon.red   { background: var(--red-bg);   color: var(--red); }

.stat-card-label { font-size: 12px; color: var(--text3); font-weight: 500; margin-bottom: 4px; }

.stat-card-value {
  font-size: 28px; font-weight: 700;
  color: var(--text); letter-spacing: -0.04em;
  line-height: 1; font-family: 'Inter', sans-serif;
}

.stat-card-note { font-size: 11px; color: var(--text4); margin-top: 4px; }

/* Beacon cards grid */
.section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 12px;
}

.section-title { font-size: 13px; font-weight: 600; color: var(--text2); letter-spacing: .01em; }

.beacon-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 12px;
}

.beacon-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 18px 20px;
  box-shadow: var(--shadow-sm);
  transition: box-shadow .2s, transform .2s, border-color .2s;
  cursor: default;
}

.beacon-card:hover { box-shadow: var(--shadow); transform: translateY(-1px); }
.beacon-card.flash { animation: bflash .4s ease; }
@keyframes bflash { 0%{background:#eff6ff;} 100%{background:var(--surface);} }

.bc-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14px;
}

.bc-left { display: flex; align-items: center; gap: 12px; }

.bc-avatar {
  width: 40px; height: 40px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 600;
}

.bc-avatar.online { background: var(--green-bg); color: var(--green); }
.bc-avatar.stale  { background: var(--amber-bg); color: var(--amber); }
.bc-avatar.offline{ background: var(--surface2); color: var(--text4); }

.bc-tag { font-family: 'JetBrains Mono', monospace; font-size: 14px; font-weight: 500; color: var(--text); }
.bc-anchor { font-size: 11px; color: var(--text3); margin-top: 1px; }

.status-dot {
  width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}
.status-dot.online { background: var(--green); box-shadow: 0 0 0 3px rgba(52,199,89,.15); }
.status-dot.stale  { background: var(--amber); }
.status-dot.offline{ background: var(--text4); }

/* Signal bar */
.bc-signal { margin-bottom: 12px; }

.bc-signal-row {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 5px;
}

.bc-signal-label { font-size: 11px; color: var(--text3); font-weight: 500; }
.bc-signal-val { font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 500; }

.signal-track {
  height: 4px; background: var(--surface3); border-radius: 99px; overflow: hidden;
}

.signal-fill { height: 100%; border-radius: 99px; transition: width .6s cubic-bezier(.4,0,.2,1); }

/* Metrics */
.bc-metrics {
  display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px;
  margin-bottom: 12px;
}

.bc-metric {
  background: var(--surface2);
  border-radius: var(--r-sm);
  padding: 8px 10px;
}

.bc-metric-label { font-size: 10px; color: var(--text4); font-weight: 500; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 3px; }
.bc-metric-val { font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 500; color: var(--text); }

/* Alert flags */
.bc-flags { display: flex; gap: 6px; flex-wrap: wrap; }

.flag {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 11px; font-weight: 500;
  padding: 3px 9px; border-radius: 99px; border: 1px solid;
}

.flag-clear  { color: var(--text4); background: var(--surface2); border-color: var(--border2); }
.flag-motion { color: var(--amber); background: var(--amber-bg); border-color: rgba(255,149,0,.3); animation: flagpulse 1.2s ease infinite; }
.flag-tamper { color: var(--red);   background: var(--red-bg);   border-color: rgba(255,59,48,.3);  animation: flagpulse 1.2s ease infinite; }
@keyframes flagpulse { 0%,100%{opacity:1;} 50%{opacity:.6;} }

.bc-footer {
  margin-top: 12px; padding-top: 10px;
  border-top: 1px solid var(--border);
  display: flex; justify-content: space-between; align-items: center;
}

.bc-mac { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text4); }
.bc-ts  { font-size: 11px; color: var(--text4); }

/* Event log */
.log-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.log-card-head {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  display: flex; justify-content: space-between; align-items: center;
}

.log-card-title { font-size: 12px; font-weight: 600; color: var(--text2); letter-spacing: .01em; }

.btn-ghost {
  background: none; border: none; cursor: pointer;
  font-size: 12px; color: var(--text3); padding: 3px 8px;
  border-radius: var(--r-sm); transition: background .12s, color .12s;
  font-family: 'Inter', sans-serif; font-weight: 500;
}

.btn-ghost:hover { background: var(--surface2); color: var(--text2); }

#log-entries {
  font-family: 'JetBrains Mono', monospace; font-size: 11px;
  color: var(--text3); padding: 12px 16px;
  max-height: 180px; overflow-y: auto;
  display: flex; flex-direction: column-reverse; gap: 2px;
}

.log-line { padding: 1.5px 0; }
.log-line.ok   { color: var(--green); }
.log-line.err  { color: var(--red); }
.log-line.info { color: var(--blue); }

.empty-state {
  grid-column: 1/-1;
  padding: 48px 24px; text-align: center;
  color: var(--text3);
}

.empty-icon { font-size: 40px; margin-bottom: 12px; opacity: .4; }
.empty-title { font-size: 15px; font-weight: 600; color: var(--text3); margin-bottom: 4px; }
.empty-sub { font-size: 13px; color: var(--text4); }

/* ═══════════════════════════════════
   MAP VIEW
═══════════════════════════════════ */
#view-map {
  padding: 0;
  overflow: hidden;
}

.map-shell {
  display: flex;
  height: calc(100vh - 52px);
}

/* Map sidebar */
.map-side {
  width: 260px; min-width: 260px;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  overflow: hidden;
}

.map-side-section {
  padding: 14px 14px 10px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.map-side-section-title {
  font-size: 10px; font-weight: 600; color: var(--text4);
  text-transform: uppercase; letter-spacing: .08em; margin-bottom: 8px;
}

.fp-upload-area {
  border: 1.5px dashed var(--border2);
  border-radius: var(--r-sm);
  padding: 12px;
  text-align: center;
  cursor: pointer;
  transition: border-color .15s, background .15s;
}

.fp-upload-area:hover { border-color: var(--blue); background: var(--blue-bg); }
.fp-upload-area input { display: none; }

.fp-upload-text { font-size: 12px; color: var(--text3); font-weight: 500; }
.fp-upload-sub  { font-size: 11px; color: var(--text4); margin-top: 2px; }

.fp-loaded {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--green-bg);
  border: 1px solid rgba(52,199,89,.3);
  border-radius: var(--r-sm);
  padding: 8px 10px;
}

.fp-loaded-name { font-size: 12px; color: var(--green); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; }

.btn-icon {
  width: 26px; height: 26px;
  background: none; border: 1px solid var(--border2);
  border-radius: 6px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  color: var(--text3); transition: all .15s; flex-shrink: 0;
}

.btn-icon:hover { background: var(--surface2); color: var(--text2); border-color: var(--border2); }
.btn-icon svg { width: 13px; height: 13px; fill: none; stroke: currentColor; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

/* Tool buttons */
.map-tools { display: flex; flex-direction: column; gap: 5px; }

.tool-btn {
  display: flex; align-items: center; gap: 8px;
  width: 100%; padding: 8px 10px;
  border: 1.5px solid var(--border2);
  border-radius: var(--r-sm);
  background: var(--surface);
  color: var(--text2); font-size: 12.5px; font-weight: 500;
  cursor: pointer; transition: all .15s; text-align: left;
  font-family: 'Inter', sans-serif;
}

.tool-btn:hover { background: var(--surface2); border-color: var(--border2); }
.tool-btn.active { background: var(--blue-bg2); border-color: rgba(0,113,227,.35); color: var(--blue); }
